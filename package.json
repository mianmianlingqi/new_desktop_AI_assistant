{
  "name": "desktop-ai-assistant",
  "version": "1.0.0",
  "description": "悬浮窗式桌面AI助手 - 支持API对接、图片上传、一键截屏",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:dir": "electron-builder --dir"
  },
  "build": {
    "appId": "com.desktop.ai-assistant",
    "productName": "Desktop AI Assistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Desktop AI Assistant",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "keywords": [
    "ai",
    "assistant",
    "desktop",
    "electron",
    "screenshot"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "canvas": "^3.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "https-proxy-agent": "^7.0.6",
    "marked": "^11.0.0",
    "screenshot-desktop": "^1.15.0"
  }
}
